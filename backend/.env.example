# Development database
DATABASE_URL="postgresql://postgres@localhost:5432/tms_dev"

# Test database — used by `npm test` when set; falls back to DATABASE_URL otherwise.
# Create a separate DB to avoid polluting development data:
#   createdb tms_test
# DATABASE_URL_TEST="postgresql://postgres@localhost:5432/tms_test"

PORT=3000
NODE_ENV=development
